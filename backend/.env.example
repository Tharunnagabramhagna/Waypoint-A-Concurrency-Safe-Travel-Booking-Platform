PORT=4000
DATABASE_URL=postgres://travel_user:travel_pass@localhost:5432/travel_booking
JWT_ACCESS_SECRET=change_this_to_a_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=another_long_random_string_different_from_access
JWT_REFRESH_EXPIRES_IN=7d
HOLD_TTL_SECONDS=600
CORS_ORIGIN=https://your-frontend-domain.com
REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@YOUR_UPSTASH_HOST:6379
UPSTASH_REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@YOUR_UPSTASH_HOST:6379
REDIS_TLS=true
# Optional if your provider expects username/password separately
# REDIS_USERNAME=default
# REDIS_PASSWORD=YOUR_UPSTASH_PASSWORD
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NODE_ENV=development

# Amadeus for Developers (https://developers.amadeus.com/)
# Sign up for a free self-service account to get your Client ID and Secret.
# If not set, the app works normally with DB/mock listings only.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
